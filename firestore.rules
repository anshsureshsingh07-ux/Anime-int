rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      // STRICT ADMIN CHECK: Email explicitly requested by user
      return isSignedIn() && (request.auth.token.email == 'anshsureshsingh07@gmail.com' && isEmailVerified());
    }

    // --- ENTITY VALIDATIONS ---
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['user', 'admin'] &&
             (!data.keys().contains('username') || (data.username is string && data.username.size() >= 1 && data.username.size() <= 32)) &&
             (!data.keys().contains('displayName') || (data.displayName is string && data.displayName.size() <= 128)) &&
             (!data.keys().contains('name') || (data.name is string && data.name.size() <= 128)) &&
             data.keys().hasAll(['uid', 'email', 'role']);
    }

    function isValidArticle(data) {
      return data.title is string && data.title.size() <= 256 &&
             data.category is string &&
             data.description is string && data.description.size() <= 1000 &&
             data.content is string && data.content.size() <= 60000 &&
             data.authorId == request.auth.uid &&
             data.keys().hasAll(['title', 'category', 'description', 'content', 'author', 'authorId', 'createdAt', 'updatedAt', 'image']) && 
             data.keys().size() >= 9;
    }

    function isValidPost(data) {
      return data.content is string && data.content.size() <= 1000 &&
             data.authorUsername is string &&
             data.authorId == request.auth.uid &&
             data.keys().hasAll(['content', 'authorId', 'authorUsername', 'author', 'authorPhoto', 'likes', 'replyCount', 'createdAt']) && data.keys().size() >= 8;
    }

    function isValidReply(data) {
      return data.content is string && data.content.size() <= 1000 &&
             data.authorUsername is string &&
             data.postId is string &&
             data.authorId == request.auth.uid &&
             data.keys().hasAll(['content', 'authorId', 'authorUsername', 'postId', 'author', 'authorPhoto', 'createdAt']) && data.keys().size() >= 7;
    }

    function isValidRecommendation(data) {
      return data.title is string && data.title.size() <= 256 &&
             data.rating is number && data.rating >= 0 && data.rating <= 10 &&
             data.image is string &&
             data.studio is string &&
             data.createdAt != null;
    }

    function isValidGalleryItem(data) {
      return data.imageUrl is string && data.imageUrl.size() <= 2048 &&
             data.caption is string && data.caption.size() <= 500 &&
             data.authorId == request.auth.uid &&
             data.keys().hasAll(['imageUrl', 'caption', 'author', 'authorId', 'authorUsername', 'likes', 'createdAt']);
    }

    // --- COLLECTION RULES ---

    // Users: Owners can read/write their own profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role == existing().role && // Prevent role change
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'username', 'name', 'bio', 'location']);
    }

    // Usernames: Unique handle reservation
    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn() && incoming().uid == request.auth.uid && isValidId(username);
      allow delete: if isSignedIn() && existing().uid == request.auth.uid;
    }

    // Community Posts
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidPost(incoming());
      allow update: if isSignedIn() && (
        (isOwner(existing().authorId) && isValidPost(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'authorPhoto', 'authorUsername', 'author'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'replyCount']))
      );
      allow delete: if isOwner(existing().authorId) || isAdmin();
    }

    // Replies
    match /replies/{replyId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReply(incoming());
      allow update: if isOwner(existing().authorId) && isValidReply(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'authorPhoto', 'authorUsername', 'author']);
      allow delete: if isOwner(existing().authorId) || isAdmin();
    }

    // Articles: Public read, User write
    match /articles/{articleId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isValidArticle(incoming());
      allow update: if isSignedIn() && (
        (isOwner(existing().authorId) && isValidArticle(incoming())) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'views', 'updatedAt']))
      );
      allow delete: if isOwner(existing().authorId) || isAdmin();
    }

    // Recommendations: Public read, Admin write
    match /recommendations/{recId} {
      allow read: if true;
      allow create: if isAdmin() && isValidRecommendation(incoming());
      allow update: if isAdmin() && isValidRecommendation(incoming());
      allow delete: if isAdmin();
    }

    // Gallery: Public read, User write
    match /gallery/{imageId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidGalleryItem(incoming());
      allow update: if isSignedIn() && (
        (isOwner(existing().authorId) && isValidGalleryItem(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['caption'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes']))
      );
      allow delete: if isOwner(existing().authorId) || isAdmin();
    }

    // OTPs: Internal verification logic (normally handled by cloud functions or restrictive rules)
    match /otps/{otpId} {
      allow get: if false; // OTPs should ideally be handled via Auth or verified via server
      allow create: if isSignedIn(); // Allow creating for verification flow
    }
  }
}
